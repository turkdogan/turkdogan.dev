<section class="mt-16 border-t border-zinc-200 pt-8 dark:border-zinc-800">
  <h2 class="mb-6 text-lg font-semibold text-zinc-900 dark:text-zinc-100">Comments</h2>
  <div id="giscus-container">
    <script
      src="https://giscus.app/client.js"
      data-repo="turkdogan/turkdogan.dev"
      data-repo-id=""
      data-category="Blog Comments"
      data-category-id=""
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="preferred_color_scheme"
      data-lang="en"
      crossorigin="anonymous"
      async
    ></script>
  </div>
  <p class="mt-4 text-sm text-zinc-500 dark:text-zinc-400">
    No GitHub account? Feel free to reach out via the <a href="/contact" class="text-accent hover:underline">contact form</a>.
  </p>
</section>
