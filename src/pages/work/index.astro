---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('work'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Work" description="Case studies from real engineering work.">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">Work</h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">
      Real problems, real trade-offs. How I approach engineering at scale.
    </p>

    <div class="mt-10 space-y-6">
      {entries.map((entry) => (
        <a href={`/work/${entry.id}`} class="group block rounded-xl border border-zinc-200 p-6 transition-colors hover:border-zinc-300 dark:border-zinc-800 dark:hover:border-zinc-700">
          <h2 class="text-lg font-semibold text-zinc-900 group-hover:text-accent dark:text-zinc-100 dark:group-hover:text-accent-light">
            {entry.data.title}
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
            {entry.data.description}
          </p>
          {entry.data.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {entry.data.tags.map((tag) => (
                <span class="rounded bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
